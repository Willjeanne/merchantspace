# ── Marketplace account ───────────────────────────────────────────────────────
# The VTEX marketplace account name (e.g. "mymarketplace")
VTEX_ACCOUNT=your-marketplace-account
VTEX_APP_KEY=
VTEX_APP_TOKEN=
VTEX_ENVIRONMENT=vtexcommercestable
NEXT_PUBLIC_VTEX_ACCOUNT=your-marketplace-account

# ── Seller account ────────────────────────────────────────────────────────────
# The VTEX seller account name and ID (often the same value)
# Create App Key/Token in: https://<your-seller-account>.myvtex.com/admin/license-manager/#/home
VTEX_SELLER_ACCOUNT=your-seller-account
VTEX_SELLER_ID=your-seller-account
VTEX_SELLER_AFFILIATE_ID=ABC
VTEX_SELLER_APP_KEY=
VTEX_SELLER_APP_TOKEN=
NEXT_PUBLIC_VTEX_SELLER_ACCOUNT=your-seller-account

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create in Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
