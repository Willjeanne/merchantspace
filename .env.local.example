# ── Marketplace account (franceretail) ──────────────────────────────────────
VTEX_ACCOUNT=franceretail
VTEX_APP_KEY=
VTEX_APP_TOKEN=
VTEX_ENVIRONMENT=vtexcommercestable
NEXT_PUBLIC_VTEX_ACCOUNT=franceretail

# ── Seller account (franceretailer1388) ─────────────────────────────────────
# Used for catalog management (create products, manage SKUs in the seller's account)
# Create in: https://franceretailer1388.myvtex.com/admin/license-manager/#/home
VTEX_SELLER_ACCOUNT=franceretailer1388
VTEX_SELLER_ID=franceretailer1388
VTEX_SELLER_AFFILIATE_ID=FRN
VTEX_SELLER_APP_KEY=
VTEX_SELLER_APP_TOKEN=

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create in Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
